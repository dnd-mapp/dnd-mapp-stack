# ============================================================
# D&D Mapp stack — environment variables template
#
# Copy this file to .env and fill in every value before
# starting the stack.
#
# Sensitive credentials (passwords, secret keys) are managed
# via Docker secrets. Create the corresponding files under
# secrets/ before starting the stack:
#
#   secrets/mariadb/root.txt               — MariaDB root password
#   secrets/auth-server/db-password.txt    — AUTH_SERVER_DB_PASSWORD / auth_app MariaDB user
#   secrets/auth-server/password-pepper.txt — AUTH_SERVER_PASSWORD_PEPPER
#   secrets/email-service/db-password.txt  — EMAIL_SERVICE_DB_PASSWORD / email_app MariaDB user
#   secrets/prisma/db-password.txt         — PRISMA_DB_PASSWORD / prisma MariaDB user
# ============================================================


# ------------------------------------------------------------
# Auth-server
# ------------------------------------------------------------

# Comma-separated list of origins allowed by the CORS policy
AUTH_SERVER_CORS_ORIGINS="https://dnd-mapp:4200"

# MariaDB connection used by the auth-server at runtime
AUTH_SERVER_DB_HOST="mariadb-server"
AUTH_SERVER_DB_PORT="3306"
AUTH_SERVER_DB_USER="change-me"
AUTH_SERVER_DB_SCHEMA="auth_db"


# ------------------------------------------------------------
# Email-service
# ------------------------------------------------------------

# Comma-separated list of origins allowed by the CORS policy
EMAIL_SERVICE_CORS_ORIGINS="http://auth-server:4350"

# MariaDB connection used by the email-service at runtime
EMAIL_SERVICE_DB_HOST="mariadb-server"
EMAIL_SERVICE_DB_PORT="3306"
EMAIL_SERVICE_DB_USER="change-me"
# Must match secrets/email-service/db-password.txt
EMAIL_SERVICE_DB_PASSWORD="change-me"
EMAIL_SERVICE_DB_SCHEMA="email_db"


# ------------------------------------------------------------
# Prisma (migration user — used by email-db-migration to run
# `prisma migrate deploy`; auth-db-migration reads this via
# Docker secret instead)
# ------------------------------------------------------------

PRISMA_DB_USER="change-me"
# Must match secrets/prisma/db-password.txt
PRISMA_DB_PASSWORD="change-me"
