# ============================================================
# D&D Mapp stack — environment variables template
#
# Copy this file to .env and fill in every value before
# starting the stack.
# ============================================================


# ------------------------------------------------------------
# Auth-server
# ------------------------------------------------------------

# Comma-separated list of origins allowed by the CORS policy
AUTH_SERVER_CORS_ORIGINS="https://dnd-mapp:4200"

# MariaDB connection used by the auth-server at runtime
AUTH_SERVER_DB_HOST="mariadb-server"
AUTH_SERVER_DB_PORT="3306"
AUTH_SERVER_DB_USER="change-me"
AUTH_SERVER_DB_PASSWORD="change-me"
AUTH_SERVER_DB_SCHEMA="auth_db"


# ------------------------------------------------------------
# Email-service
# ------------------------------------------------------------

# Comma-separated list of origins allowed by the CORS policy
EMAIL_SERVICE_CORS_ORIGINS="http://auth-server:4350"

# MariaDB connection used by the email-service at runtime
EMAIL_SERVICE_DB_HOST="mariadb-server"
EMAIL_SERVICE_DB_PORT="3306"
EMAIL_SERVICE_DB_USER="change-me"
EMAIL_SERVICE_DB_PASSWORD="change-me"
EMAIL_SERVICE_DB_SCHEMA="email_db"


# ------------------------------------------------------------
# Prisma (shared migration user — used by both *-db-migration
# services to run `prisma migrate deploy`)
# ------------------------------------------------------------

PRISMA_DB_USER="change-me"
PRISMA_DB_PASSWORD="change-me"
